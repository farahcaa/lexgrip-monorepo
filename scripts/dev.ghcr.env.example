# Copy this file to scripts/dev.ghcr.env and fill in real values.
# scripts/dev.ghcr.env is gitignored.

# Required
GHCR_USERNAME=farahcaa
GHCR_TOKEN=replace_with_github_pat

# Optional
GHCR_EMAIL=your-farahca@mail.uc.edu
GHCR_SERVER=ghcr.io
K8S_NAMESPACE=default

# Space-separated list of secret names to create/update.
# Keep these defaults unless you also change imagePullSecrets in manifests.
GHCR_SECRET_NAMES="ghcr-secret registry-pull ghcr-pull"
